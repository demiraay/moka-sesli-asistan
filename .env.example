# LLM modu: 0 = Ollama (lokal), 1 = OpenAI, 2 = Groq (ucretsiz tier, onerilen)
LLM_MODE=2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
OPENAI_MODEL=gpt-4o

# Groq (https://console.groq.com — ucretsiz API key)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Cevap uretimi icin buyuk model, router (arac secimi) icin hizli kucuk model.
# Ayri modeller = Groq free tier'da ayri dakikalik token kovalari (TPM).
GROQ_MODEL=openai/gpt-oss-120b
GROQ_ROUTER_MODEL=openai/gpt-oss-20b

# STT: GROQ_API_KEY doluysa Groq Whisper API (whisper-large-v3-turbo) kullanilir,
# degilse asagidaki lokal whisper modeline duser (ffmpeg gerekir).
WHISPER_MODEL=base
WHISPER_LANGUAGE=tr
WHISPER_DEVICE=cpu
VOICE_OUTPUT_DIR=voice_output

# TTS: dogal Turkce ses icin ElevenLabs (flash modeli dusuk gecikme icin)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# Admin paneli guvenligi: parola bos birakilirsa panel korumasiz calisir (sadece gelistirme icin)
ADMIN_PASSWORD=
ADMIN_SECRET_KEY=
ADMIN_HOST=127.0.0.1
ADMIN_PORT=5050
ADMIN_DEBUG=false

WHATSAPP_BRIDGE_HOST=127.0.0.1
WHATSAPP_BRIDGE_PORT=5051
WHATSAPP_BRIDGE_DEBUG=false
# Koprunun /whatsapp/message ucunu korur: doldurulursa Node botu ayni token'i
# X-Bridge-Token basligiyla gonderir, tokensiz istekler 401 alir. Bos = korumasiz.
WHATSAPP_BRIDGE_TOKEN=
